<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      xmlns:ui="clr-namespace:Content.Client.Shuttles.UI"
                      Title="{Loc 'turret-control-console-window-title'}"
                      MinSize="648 648">
    <BoxContainer Orientation="Vertical" Margin="5 5 5 5" SeparationOverride="10">
        <BoxContainer Name="MainContent" Orientation="Horizontal" VerticalExpand="True" Margin="4">
            <ui:ShuttleNavControl Name="RadarScreen" Margin="8" HorizontalExpand = "True" VerticalExpand = "True"/>
            <BoxContainer Name="Controls" Orientation="Vertical" VerticalExpand="True" Margin="4" MinSize="100 0">
                <Button Name="ResetTarget" Text="{Loc 'turret-control-console-ui-reset'}" />
                <Button Name="FireCannons" Text="{Loc 'turret-control-console-ui-fire'}" VerticalExpand = "True"/>
            </BoxContainer>
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>