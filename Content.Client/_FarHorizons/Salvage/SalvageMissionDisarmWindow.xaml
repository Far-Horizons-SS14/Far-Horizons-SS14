            <Label HorizontalExpand="True" />
            <Button Name="SubmitButton" Disabled="True" Text="{Loc 'salvage-mission-disarm-ui-menu-submit-button'}" Margin="5" />
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>